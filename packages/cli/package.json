{
  "name": "@openrender/cli",
  "version": "0.1.0",
  "description": "Command-line interface for openRender",
  "license": "MIT",
  "type": "module",
  "bin": {
    "openrender": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@openrender/core": "workspace:*",
    "@openrender/doctor": "workspace:*"
  }
}
