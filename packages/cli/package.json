{
  "name": "@openrender/cli",
  "version": "1.0.2",
  "description": "Command-line interface for openRender",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dt-pirate/openrender.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/dt-pirate/openrender/issues"
  },
  "homepage": "https://github.com/dt-pirate/openrender#readme",
  "keywords": [
    "game-dev",
    "phaser",
    "godot",
    "love2d",
    "pixi",
    "canvas",
    "three",
    "unity",
    "assets",
    "sprites",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "openrender": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "README.md",
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepack": "pnpm build",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@openrender/adapter-canvas": "workspace:*",
    "@openrender/adapter-godot": "workspace:*",
    "@openrender/adapter-love2d": "workspace:*",
    "@openrender/adapter-phaser": "workspace:*",
    "@openrender/adapter-pixi": "workspace:*",
    "@openrender/adapter-three": "workspace:*",
    "@openrender/adapter-unity": "workspace:*",
    "@openrender/core": "workspace:*",
    "@openrender/doctor": "workspace:*",
    "@openrender/harness-visual": "workspace:*",
    "@openrender/reporter": "workspace:*"
  }
}
