{
  "name": "@openrender/adapter-unity",
  "version": "0.9.2",
  "description": "Unity adapter helpers for openRender",
  "license": "Apache-2.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dt-pirate/openrender.git",
    "directory": "packages/adapters/unity"
  },
  "bugs": {
    "url": "https://github.com/dt-pirate/openrender/issues"
  },
  "homepage": "https://github.com/dt-pirate/openrender#readme",
  "keywords": [
    "game-dev",
    "unity",
    "assets",
    "sprites"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.tsbuildinfo"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepack": "pnpm build",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "@openrender/core": "workspace:*"
  }
}
