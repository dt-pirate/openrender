{
  "name": "openrender-repo",
  "version": "0.3.0",
  "private": true,
  "description": "open infrastructure for AI agents turning generated media into engine-ready playable projects",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dt-pirate/openrender.git"
  },
  "bugs": {
    "url": "https://github.com/dt-pirate/openrender/issues"
  },
  "homepage": "https://github.com/dt-pirate/openrender#readme",
  "keywords": [
    "game-dev",
    "phaser",
    "godot",
    "love2d",
    "assets",
    "sprites",
    "ai-agents"
  ],
  "packageManager": "pnpm@10.33.0",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "clean": "find packages -type d -name dist -prune -exec rm -rf {} + && find packages -type f \\( -name '*.tsbuildinfo' -o -name 'tsconfig.tsbuildinfo' \\) -delete",
    "dev:cli": "pnpm --filter @openrender/cli build && node packages/cli/dist/index.js",
    "lint": "pnpm typecheck",
    "test": "pnpm build && node --test \"packages/*/dist/**/*.test.js\" \"packages/adapters/*/dist/**/*.test.js\"",
    "typecheck": "tsc -b --pretty false"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
